OPENAI_API_KEY=your-openai-api-key

# For Codespaces, use: DATABASE_URL=postgresql://user:password@localhost:5432/hinglish_chatbot

# n8n Workflow Automation
N8N_WEBHOOK_URL=https://n8n.chinmayramraika.in
N8N_API_KEY=your-project-specific-n8n-api-key

# Sentry / Glitchtip error reporting (DSN at errors.chinmayramraika.in)
# Sourced from Infisical: main-host:/host-page/AAKHARA_GLITCHTIP_DSN
# Backend reads SENTRY_DSN; frontend reads REACT_APP_SENTRY_DSN at build.
# Leave unset to disable error reporting.
SENTRY_DSN=
REACT_APP_SENTRY_DSN=
